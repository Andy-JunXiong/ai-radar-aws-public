# Copy this file to .env and provide your own values locally.
# Never commit the populated .env file.

OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini
GPT_VISUAL_MODEL=gpt-4.1-mini

ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

PERPLEXITY_API_KEY=your_perplexity_api_key
PERPLEXITY_MODEL=sonar

GEMINI_API_KEY=your_gemini_api_key
GEMINI_IMAGE_MODEL=gemini-2.0-flash-exp

AWS_REGION=your_aws_region
S3_BUCKET=your_bucket_name
AI_RADAR_S3_BUCKET=your_bucket_name
AI_RADAR_DEV_INBOX_S3_ENABLED=false
AI_RADAR_DEV_INBOX_S3_KEY=your/dev-inbox/key.json

RADAR_TIME_WINDOW_HOURS=24
MAX_SIGNALS_PER_RUN=50
LLM_MODEL=your_default_model
LOG_LEVEL=INFO
RADAR_TIMEZONE=UTC
OBSIDIAN_VAULT_PATH=your_optional_local_path
