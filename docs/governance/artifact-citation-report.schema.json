{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-radar-lab.local/schemas/artifact-citation-report.v1.json",
  "title": "AI Radar Artifact Citation Integrity Report",
  "type": "object",
  "required": [
    "schema_version",
    "report_boundary",
    "summary",
    "findings"
  ],
  "properties": {
    "schema_version": {
      "const": "artifact_citation_report.v1"
    },
    "report_boundary": {
      "type": "object",
      "required": [
        "mode",
        "decision_boundary",
        "writes_data",
        "hard_enforcement",
        "not_for"
      ],
      "properties": {
        "mode": {
          "const": "read_only"
        },
        "decision_boundary": {
          "const": "artifact_review_readiness_only"
        },
        "writes_data": {
          "const": false
        },
        "hard_enforcement": {
          "const": false
        },
        "not_for": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        }
      },
      "additionalProperties": true
    },
    "summary": {
      "type": "object",
      "required": [
        "artifact_count",
        "artifact_ok_count",
        "finding_count",
        "error_count",
        "warning_count",
        "readiness"
      ],
      "properties": {
        "artifact_count": {
          "type": "integer",
          "minimum": 0
        },
        "artifact_ok_count": {
          "type": "integer",
          "minimum": 0
        },
        "finding_count": {
          "type": "integer",
          "minimum": 0
        },
        "error_count": {
          "type": "integer",
          "minimum": 0
        },
        "warning_count": {
          "type": "integer",
          "minimum": 0
        },
        "readiness": {
          "enum": [
            "ready_for_human_absorption",
            "citation_retrofit_needed",
            "no_artifacts_found"
          ]
        }
      },
      "additionalProperties": true
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "code",
          "severity",
          "path",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "severity": {
            "enum": [
              "error",
              "warning",
              "info"
            ]
          },
          "path": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
